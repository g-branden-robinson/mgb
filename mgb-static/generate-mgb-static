isinpath () {
        command -v $1 >&/dev/null
}

for i in podman buildah; do
    if ! isinpath $i; then
        echo "$0: $i is a required dependency for this script" >&2
        EXIT=true
    fi
done

if [ "$EXIT" = true ]; then
    exit 1
fi

usage() {
    name=${0##*/}
    cat << EOF >&2
This script can build a static binary for mgb, like this:
./$name [amd64|i386|arm64v8|arm32v7] [tag|latest]
Make sure your architecture is compatible.
EOF
    exit 1
}

case $1 in
    amd64)
        ext=$1
        ;;
    arm64v8)
        ext=$1
        ;;
    arm32v7)
        ext=$1
        ;;
    i386)
        ext=$1
        ;;
    *)
        usage
        ;;
esac

case $2 in
    latest)
        TCMD='date +latest%Y%m%d'
        ;;
    tag)
        TCMD='git tag|tail -n 1'
        ;;
    *)
        usage
        ;;
esac

# Create the Containerfile (UNTESTED BY GBR)
cat << EOF > Containerfile
FROM docker.io/$ext/alpine
RUN apk upgrade
RUN apk add git libbsd-static libbsd-dev ncurses-dev musl-dev ncurses-static gcc make
RUN git clone https://github.com/g-branden-robinson/mgb.git
WORKDIR mgb
RUN TAG=\$($TCMD); \
    git checkout \$TAG; \
    make STATIC=1; \
    strip mgb; \
    ln mgb mgb-\$TAG-static-$ext
EOF


cat << EOF > ./helper-script
#!/bin/sh
mnt=\$(podman image mount localhost/mgb-static)
cp \$mnt/mgb/mgb-*static-* .
EOF
chmod 755 ./helper-script

podman image rm localhost/mgb-static
buildah build -f Containerfile -t mgb-static
podman unshare ./helper-script

# Clean up the mess
rm -f Containerfile helper-script
podman image rm localhost/mgb-static
